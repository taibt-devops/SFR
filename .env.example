# Sao chép thành `.env` (đã được .gitignore bỏ qua) rồi điền giá trị thật. KHÔNG commit `.env`.

# ── Proxy (server/proxy.mjs) — token sống DUY NHẤT ở đây ──
# Lấy token bằng:  claude setup-token
CLAUDE_TOKEN=
# Lớp khóa nhẹ giữa frontend ↔ proxy (đặt chuỗi ngẫu nhiên). Khi expose ra ngoài, khóa thật = Cloudflare Access.
PROXY_SECRET=
# (tùy chọn) cổng proxy, mặc định 8787
# PROXY_PORT=8787

# ── Frontend (Vite, prefix VITE_ mới lộ ra client) ──
# URL proxy local; phải KHỚP PROXY_SECRET ở trên.
VITE_PROXY_URL=http://localhost:8787
VITE_PROXY_SECRET=
# Whisper STT local (whisper.cpp server) — cho luyện nói (M6). Mặc định endpoint /inference cổng 8080.
VITE_WHISPER_URL=http://localhost:8080/inference
